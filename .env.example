# Variáveis de ambiente do servidor CAD Paramétrico
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env com valores reais no repositório.

# ── Google Gemini API ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Configurações do servidor ─────────────────────────────────────────────────
CAD_SERVER_HOST=127.0.0.1
CAD_SERVER_PORT=8000

# ── Modelo Gemini ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
